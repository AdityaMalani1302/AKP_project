# Backend Environment Variables Example
# Copy this file to .env and fill in your values

# Database Connection
#SQL_USER=your_sql_username
#SQL_PASSWORD=your_sql_password
#SQL_SERVER=localhost
#DB_NAME_1=IcSoftVer3
#DB_NAME_2=IcSoftReportVer3
#DB_NAME_3=IcSoftLedgerVer3

# Server Settings
#PORT=5000
#NODE_ENV=production
#JWT_SECRET=your_super_secret_jwt_key

# CORS Origins (for local network access)
#CORS_ORIGIN=http://192.168.1.10:5173

# Cloud Deployment (set this after deploying frontend to Vercel)
#FRONTEND_URL=https://your-app.vercel.app

# WhatsApp Cloud API (for sending reports via WhatsApp)
#WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
#WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
#WHATSAPP_API_VERSION=v21.0
# WHATSAPP_TEMPLATE_NAME=scheduled_data_export   # Utility template namen
#WHATSAPP_TEMPLATE_LANG=en

# AI Chatbot (Groq - free tier, very fast)
# Get your free API key from https://console.groq.com/keys
#GROQ_API_KEY=your_groq_api_key
